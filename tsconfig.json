{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"], // allows TypeScript to understand the @ symbol as a path alias for the root (or any other folder or folder within)
      "@/assets/*": ["./assets/*"] // additional path alias for @/assets/* to directly point to the assets folder to tell TypeScript how to resolve imports for assets
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
