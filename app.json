{
  "expo": {
    "name": "in-motion-mobile",
    "slug": "in-motion-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/in-motion-black-icon-background.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/in-motion-white-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/in-motion-orangegold-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/in-motion-black-icon.png",
          "imageWidth": 200,
          "resizeMode": "cover",
          "backgroundColor": "hsl(0, 0.00%, 98.00%)" // "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
